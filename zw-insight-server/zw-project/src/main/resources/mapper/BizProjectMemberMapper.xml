<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zwinsight.project.mapper.BizProjectMemberMapper">

    <resultMap id="BaseResultMap" type="com.zwinsight.project.domain.BizProjectMember">
        <id column="id" property="id"/>
        <result column="project_id" property="projectId"/>
        <result column="user_id" property="userId"/>
        <result column="user_name" property="userName"/>
        <result column="project_roles" property="projectRoles"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="join_date" property="joinDate"/>
        <result column="status" property="status"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
        <result column="version" property="version"/>
    </resultMap>

    <select id="selectMemberPage" resultMap="BaseResultMap">
        SELECT *
        FROM biz_project_member
        WHERE project_id = #{projectId}
          AND deleted = 0
          AND status = 1
        <if test="role != null and role != ''">
            AND JSON_CONTAINS(project_roles, CONCAT('"', #{role}, '"'))
        </if>
        ORDER BY created_at DESC
    </select>

</mapper>
